    "dry-run": "wrangler deploy --dry-run --outdir=dist",
    "typecheck": "tsc --noEmit",
    "cf-typegen": "wrangler types --env-interface CloudflareBindings"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "firebase-auth-cloudflare-workers": "^2.0.6",
    "firebase-rest-firestore": "^1.5.0",
    "hono": "^4.12.12",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260412.1",
    "typescript": "^6.0.2",
    "wrangler": "^4.81.1"
  }
}
